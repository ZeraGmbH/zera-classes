  <MULOPC Description="OPeration Complete" Type="Model,Query,Command" ScpiPath="*OPC"/>
  <MULESE Description="Event Status Enable" Type="Model,Query,Command+Par" ScpiPath="*ESE"/>
  <MULSRE Description="Service Request Enable" Type="Model,Query,Command+Par" ScpiPath="*SRE"/>
  <MULCLS Description="Clear Status" Type="Model,Command" ScpiPath="*CLS"/>
  <MULRST Description="Reset" Type="Model,Command" ScpiPath="*RST"/>
  <MULIDN Description="Identification query" Type="Model,Query" ScpiPath="*IDN"/>
  <MULESR Description="Event Status Register" Type="Model,Query" ScpiPath="*ESR"/>
  <MULSTB Description="Status Byte query" Type="Model,Query" ScpiPath="*STB"/>
  <MULTST Description="Self-Test query" Type="Model,Query" ScpiPath="*TST"/>
  <SYSTEM Type="Model,Node">
