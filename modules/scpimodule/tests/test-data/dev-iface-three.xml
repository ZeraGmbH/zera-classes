    <IL3 Description="Actual peak value" Type="Command" Unit="A" ScpiPath="CONFIGURE:RNG1:IL3"/>
    <UAUX Description="Actual peak value" Type="Command" Unit="V" ScpiPath="CONFIGURE:RNG1:UAUX"/>
    <IAUX Description="Actual peak value" Type="Command" Unit="A" ScpiPath="CONFIGURE:RNG1:IAUX"/>
    <F Description="Actual frequency" Type="Command" Unit="Hz" ScpiPath="CONFIGURE:RNG1:F"/>
   </RNG1>
  </CONFIGURE>
  <READ Type="Model,Node,Query" ScpiPath="READ">
   <RNG1 Type="Node,Query" ScpiPath="READ:RNG1">
    <UL1 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="READ:RNG1:UL1"/>
    <UL2 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="READ:RNG1:UL2"/>
    <UL3 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="READ:RNG1:UL3"/>
    <IL1 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="READ:RNG1:IL1"/>
    <IL2 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="READ:RNG1:IL2"/>
    <IL3 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="READ:RNG1:IL3"/>
    <UAUX Description="Actual peak value" Type="Query" Unit="V" ScpiPath="READ:RNG1:UAUX"/>
    <IAUX Description="Actual peak value" Type="Query" Unit="A" ScpiPath="READ:RNG1:IAUX"/>
    <F Description="Actual frequency" Type="Query" Unit="Hz" ScpiPath="READ:RNG1:F"/>
   </RNG1>
  </READ>
  <INIT Type="Model,Node,Command" ScpiPath="INIT">
   <RNG1 Type="Node,Command" ScpiPath="INIT:RNG1">
    <UL1 Description="Actual peak value" Type="Command" Unit="V" ScpiPath="INIT:RNG1:UL1"/>
    <UL2 Description="Actual peak value" Type="Command" Unit="V" ScpiPath="INIT:RNG1:UL2"/>
    <UL3 Description="Actual peak value" Type="Command" Unit="V" ScpiPath="INIT:RNG1:UL3"/>
