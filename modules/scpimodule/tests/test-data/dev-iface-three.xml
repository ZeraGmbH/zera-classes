    <UAUX Description="Actual peak value" Type="Query" Unit="V" ScpiPath="FETCH:RNG1:UAUX"/>
    <IAUX Description="Actual peak value" Type="Query" Unit="A" ScpiPath="FETCH:RNG1:IAUX"/>
    <F Description="Actual frequency" Type="Query" Unit="Hz" ScpiPath="FETCH:RNG1:F"/>
   </RNG1>
  </FETCH>
  <STATUS Type="Model,Node">
   <DEV1 Type="Node">
    <ADJCHKSUM Description="Adjustment data checksum device" Type="Query" ScpiPath="STATUS:DEV1:ADJCHKSUM"/>
    <ADJUSTMENT Description="Adjustment information" Type="Query" ScpiPath="STATUS:DEV1:ADJUSTMENT"/>
    <VERSION Type="Node">
     <CONTROLER Description="Controller version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:CONTROLER"/>
     <DSPSERVER Description="DSP-server version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:DSPSERVER"/>
     <DSP Description="DSP software version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:DSP"/>
     <FPGA Description="FPGA version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:FPGA"/>
     <PCBSERVER Description="PCB-server version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:PCBSERVER"/>
     <PCB Description="PCB version" Type="Query" ScpiPath="STATUS:DEV1:VERSION:PCB"/>
    </VERSION>
    <CPUINFO Description="CPU/SOM info" Type="Query" ScpiPath="STATUS:DEV1:CPUINFO"/>
    <DSP Type="Node">
     <BUSYPERCENT Description="DSP Busy value [%]" Type="Query" Unit="%" ScpiPath="STATUS:DEV1:DSP:BUSYPERCENT"/>
     <TIMEMS Description="DSP ms timer" Type="Query" ScpiPath="STATUS:DEV1:DSP:TIMEMS"/>
     <PERIODCOUNT Description="DSP period count" Type="Query" ScpiPath="STATUS:DEV1:DSP:PERIODCOUNT"/>
    </DSP>
    <DEVTYPE Description="Device type e.g 'mt310s2' or 'com5003'" Type="Query" ScpiPath="STATUS:DEV1:DEVTYPE"/>
    <RELEASE Description="Release number" Type="Query" ScpiPath="STATUS:DEV1:RELEASE"/>
    <AUTHORIZATION Description="Adjustment values write permission" Type="Query" ScpiPath="STATUS:DEV1:AUTHORIZATION"/>
    <SERIAL Description="Serial number" DataType="STRING" RegEx="^\d{9}$" Type="Query,Command+Par" ScpiPath="STATUS:DEV1:SERIAL"/>
   </DEV1>
   <QUESTIONABLE Type="Node">
    <CONDITION Type="Query" ScpiPath="STATUS:QUESTIONABLE:CONDITION"/>
    <PTRANSITION Type="Query,Command+Par" ScpiPath="STATUS:QUESTIONABLE:PTRANSITION"/>
    <NTRANSITION Type="Query,Command+Par" ScpiPath="STATUS:QUESTIONABLE:NTRANSITION"/>
    <EVENT Type="Query" ScpiPath="STATUS:QUESTIONABLE:EVENT"/>
    <ENABLE Type="Query,Command+Par" ScpiPath="STATUS:QUESTIONABLE:ENABLE"/>
   </QUESTIONABLE>
