    <UAUX Description="Actual peak value" Type="Command" Unit="V" ScpiPath="INIT:RNG1:UAUX"/>
    <IAUX Description="Actual peak value" Type="Command" Unit="A" ScpiPath="INIT:RNG1:IAUX"/>
    <F Description="Actual frequency" Type="Command" Unit="Hz" ScpiPath="INIT:RNG1:F"/>
   </RNG1>
  </INIT>
  <FETCH Type="Model,Node,Query" ScpiPath="FETCH">
   <RNG1 Type="Node,Query" ScpiPath="FETCH:RNG1">
    <UL1 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="FETCH:RNG1:UL1"/>
    <UL2 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="FETCH:RNG1:UL2"/>
