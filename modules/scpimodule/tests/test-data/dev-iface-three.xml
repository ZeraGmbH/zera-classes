<!DOCTYPE SCPIModel>
<MODELLIST>
 <DEVICE>DEMO</DEVICE>
 <RELEASE></RELEASE>
 <MODELS>
  <CONFIGURATION Type="Model,Node">
   <SYST Type="Node">
    <NAMESESSION Description="Session name" ValidPar="Default,EMOB AC,EMOB DC,DC: 4*Voltage / 1*Current" DataType="STRING" Type="Query,Command+Par" ScpiPath="CONFIGURATION:SYST:NAMESESSION"/>
    <XSESSION Description="XSession name" ValidPar="Foo,Bar" DataType="STRING" Type="Query,Command+Par" ScpiPath="CONFIGURATION:SYST:XSESSION">
     <CATALOG Type="Query" ScpiPath="CONFIGURATION:SYST:XSESSION:CATALOG"/>
    </XSESSION>
    <SESSION Type="Node">
     <CATALOG Type="Query" ScpiPath="CONFIGURATION:SYST:SESSION:CATALOG"/>
    </SESSION>
   </SYST>
   <RNG1 Type="Node">
    <GROUPING Description="Channel grouping on/off" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:GROUPING" Max="1"/>
    <IGNORERMSVAL Description="Percentage of nominal range below which channel values are ignored" DataType="DOUBLE" Min="0" Type="Query,Command+Par" Unit="%" ScpiPath="CONFIGURATION:RNG1:IGNORERMSVAL" Max="2"/>
    <ENABLEIGNORERMSVAL Description="Enable or disable channel ignore limit option" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:ENABLEIGNORERMSVAL" Max="1"/>
    <UL1 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:UL1:INVERTPHASE" Max="1"/>
    </UL1>
    <UL2 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:UL2:INVERTPHASE" Max="1"/>
    </UL2>
    <UL3 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:UL3:INVERTPHASE" Max="1"/>
    </UL3>
    <IL1 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:IL1:INVERTPHASE" Max="1"/>
    </IL1>
    <IL2 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:IL2:INVERTPHASE" Max="1"/>
    </IL2>
    <IL3 Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:IL3:INVERTPHASE" Max="1"/>
    </IL3>
    <UAUX Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:UAUX:INVERTPHASE" Max="1"/>
    </UAUX>
    <IAUX Type="Node">
     <INVERTPHASE Description="Inverted Phase" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:IAUX:INVERTPHASE" Max="1"/>
    </IAUX>
    <RNGAUTO Description="Range automatic on/off" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:RNGAUTO" Max="1"/>
    <RNGTIMER Description="Range timer for range decrease" DataType="INTEGER" Min="0" Type="Query,Command+Par" ScpiPath="CONFIGURATION:RNG1:RNGTIMER" Max="600000"/>
   </RNG1>
  </CONFIGURATION>
  <SENSE Type="Model,Node">
   <RNG1 Type="Node">
    <UL1 Type="Node">
     <RANGE Description="Channel's range" ValidPar="250V,8V,100mV" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:UL1:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:UL1:RANGE:CATALOG"/>
     </RANGE>
    </UL1>
    <UL2 Type="Node">
     <RANGE Description="Channel's range" ValidPar="250V,8V,100mV" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:UL2:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:UL2:RANGE:CATALOG"/>
     </RANGE>
    </UL2>
    <UL3 Type="Node">
     <RANGE Description="Channel's range" ValidPar="250V,8V,100mV" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:UL3:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:UL3:RANGE:CATALOG"/>
     </RANGE>
    </UL3>
    <IL1 Type="Node">
     <RANGE Description="Channel's range" ValidPar="10A,5A,2.5A,1.0A,500mA,250mA,100mA,50mA,25mA" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:IL1:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:IL1:RANGE:CATALOG"/>
     </RANGE>
    </IL1>
    <IL2 Type="Node">
     <RANGE Description="Channel's range" ValidPar="10A,5A,2.5A,1.0A,500mA,250mA,100mA,50mA,25mA" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:IL2:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:IL2:RANGE:CATALOG"/>
     </RANGE>
    </IL2>
    <IL3 Type="Node">
     <RANGE Description="Channel's range" ValidPar="10A,5A,2.5A,1.0A,500mA,250mA,100mA,50mA,25mA" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:IL3:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:IL3:RANGE:CATALOG"/>
     </RANGE>
    </IL3>
    <UAUX Type="Node">
     <RANGE Description="Channel's range" ValidPar="250V,8V,100mV" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:UAUX:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:UAUX:RANGE:CATALOG"/>
     </RANGE>
    </UAUX>
    <IAUX Type="Node">
     <RANGE Description="Channel's range" ValidPar="--" DataType="STRING" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:IAUX:RANGE">
      <CATALOG Type="Query" ScpiPath="SENSE:RNG1:IAUX:RANGE:CATALOG"/>
     </RANGE>
    </IAUX>
    <OVERLOAD Description="Overload" DataType="BOOL" Min="0" Type="Query,Command+Par" ScpiPath="SENSE:RNG1:OVERLOAD" Max="1"/>
   </RNG1>
  </SENSE>
  <MEASURE Type="Model,Node,Query" ScpiPath="MEASURE">
   <RNG1 Type="Node,Query" ScpiPath="MEASURE:RNG1">
    <UL1 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="MEASURE:RNG1:UL1"/>
    <UL2 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="MEASURE:RNG1:UL2"/>
    <UL3 Description="Actual peak value" Type="Query" Unit="V" ScpiPath="MEASURE:RNG1:UL3"/>
    <IL1 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="MEASURE:RNG1:IL1"/>
    <IL2 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="MEASURE:RNG1:IL2"/>
    <IL3 Description="Actual peak value" Type="Query" Unit="A" ScpiPath="MEASURE:RNG1:IL3"/>
    <UAUX Description="Actual peak value" Type="Query" Unit="V" ScpiPath="MEASURE:RNG1:UAUX"/>
    <IAUX Description="Actual peak value" Type="Query" Unit="A" ScpiPath="MEASURE:RNG1:IAUX"/>
    <F Description="Actual frequency" Type="Query" Unit="Hz" ScpiPath="MEASURE:RNG1:F"/>
   </RNG1>
  </MEASURE>
  <CONFIGURE Type="Model,Node,Command" ScpiPath="CONFIGURE">
   <RNG1 Type="Node,Command" ScpiPath="CONFIGURE:RNG1">
    <UL1 Description="Actual peak value" Type="Command" Unit="V" ScpiPath="CONFIGURE:RNG1:UL1"/>
    <UL2 Description="Actual peak value" Type="Command" Unit="V" ScpiPath="CONFIGURE:RNG1:UL2"/>
